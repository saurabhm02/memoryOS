# Copy to .env and fill in your keys. Never commit .env.

# --- LLM + embeddings: Google Gemini (via Cognee 1.2.1 / LiteLLM) ---
# One Google AI Studio key, used for both the LLM and embeddings.
GEMINI_API_KEY=
LLM_API_KEY=
EMBEDDING_API_KEY=
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-2.5-flash
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini/gemini-embedding-001
EMBEDDING_DIMENSIONS=3072

# --- App database (the evidence ledger) — PostgreSQL ---
# Local (docker compose up -d postgres):
DATABASE_URL=postgresql+psycopg2://dev:dev@localhost:5432/recallos
# Managed (e.g. Aiven): use the provided URL and append ?sslmode=require

# --- Cognee local stores (SQLite + Kuzu + LanceDB, under backend/.cognee/) ---
COGNEE_SYSTEM_DIR=./.cognee/system
COGNEE_DATA_DIR=./.cognee/data
# We own auth and isolate by dataset-per-user, so Cognee's own access control is off.
ENABLE_BACKEND_ACCESS_CONTROL=false

DEMO_USER_ID=demo
# The sandboxed demo account (used by `python -m recallos.scripts.reset_demo`).
DEMO_EMAIL=demo@recallos.app
# Allowed CORS origins for the frontend (comma-separated).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Authentication (provider-agnostic OIDC; Supabase is the initial provider) ---
# The backend only verifies JWTs against the issuer's JWKS — swap providers by config.
# Supabase: OIDC_ISSUER   = https://<project-ref>.supabase.co/auth/v1
#           OIDC_JWKS_URL = https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
#           OIDC_AUDIENCE = authenticated
OIDC_ISSUER=
OIDC_AUDIENCE=authenticated
OIDC_JWKS_URL=
