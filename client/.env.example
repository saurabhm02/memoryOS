# RecallOS frontend — copy to .env.local and fill in. Never commit .env.local.

# Backend API
VITE_API_URL=http://localhost:8000

# Supabase (authentication only). Project URL + publishable/anon key.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# Sandboxed demo account powering the "Try the Demo" CTA.
VITE_DEMO_EMAIL=demo@recallos.app
VITE_DEMO_PASSWORD=
